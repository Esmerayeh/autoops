AUTOOPS_ENV=development
AUTOOPS_SECRET_KEY=change-me
AUTOOPS_DATABASE_URL=sqlite:///autoops.db
AUTOOPS_DEFAULT_ADMIN_USERNAME=admin
AUTOOPS_DEFAULT_ADMIN_PASSWORD=admin123!
AUTOOPS_ENABLE_SELF_HEALING=true
AUTOOPS_HEALING_DRY_RUN=true
AUTOOPS_WARNING_THRESHOLD=70
AUTOOPS_CRITICAL_THRESHOLD=85
AUTOOPS_SAMPLE_INTERVAL_SECONDS=2
AUTOOPS_MAX_HISTORY_POINTS=180
AUTOOPS_DATA_RETENTION_HOURS=168
AUTOOPS_JSON_LOGS=false
AUTOOPS_COOKIE_SECURE=false
AUTOOPS_ENABLE_SIGNUP=true
