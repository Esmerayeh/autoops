AUTOOPS_ENV=development
AUTOOPS_SECRET_KEY=change-me
AUTOOPS_DATABASE_URL=sqlite:///autoops.db
AUTOOPS_DEFAULT_ADMIN_USERNAME=admin
AUTOOPS_DEFAULT_ADMIN_PASSWORD=
AUTOOPS_SEED_DEFAULT_ADMIN=false
AUTOOPS_ENABLE_SELF_HEALING=true
AUTOOPS_HEALING_DRY_RUN=true
AUTOOPS_WARNING_THRESHOLD=70
AUTOOPS_CRITICAL_THRESHOLD=85
AUTOOPS_SAMPLE_INTERVAL_SECONDS=2
AUTOOPS_MAX_HISTORY_POINTS=180
AUTOOPS_DATA_RETENTION_HOURS=168
AUTOOPS_JSON_LOGS=false
AUTOOPS_COOKIE_SECURE=false
AUTOOPS_ENABLE_SIGNUP=true
AUTOOPS_DISTRIBUTED_MODE=false
AUTOOPS_CLUSTER_NAME=autoops-local-cluster
AUTOOPS_NODE_ID=autoops-node-1
AUTOOPS_NODE_NAME=AutoOps Control Plane
AUTOOPS_NODE_ROLE=control-plane
AUTOOPS_NODE_REGION=local
AUTOOPS_NODE_ENVIRONMENT=development
AUTOOPS_NODE_HEARTBEAT_TTL_SECONDS=30
AUTOOPS_CLUSTER_ALLOW_REMOTE_AGENTS=false
AUTOOPS_STREAM_BACKEND=inmemory
AUTOOPS_TENANCY_ENABLED=false
AUTOOPS_DEFAULT_TENANT=default

DATABASE_URL=postgresql+psycopg://autoops:autoops@localhost:5432/autoops
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me
BOOTSTRAP_TOKEN=change-me-bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@local.autoops
BOOTSTRAP_ADMIN_PASSWORD=admin123!
AGENT_ENROLLMENT_SECRET=change-me-agent
CONTROL_PLANE_URL=http://localhost:8000/api/v1
TENANT_SLUG=demo
ENROLLMENT_TOKEN=change-me-agent
NODE_UID=node-local
HOSTNAME=localhost
REGION=local
